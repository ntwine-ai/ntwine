<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NtwineApp.Views.ModelPickerView">

    <Border Background="#0f0b15" CornerRadius="16" BorderBrush="#2a2238" BorderThickness="1"
            Padding="0" Width="500" MaxHeight="600">
        <DockPanel>

            <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0" Spacing="12">
                <DockPanel>
                    <TextBlock Text="Add Model" FontSize="16" FontWeight="Bold" Foreground="#e8e0f4" DockPanel.Dock="Left" />
                    <TextBlock Text="{Binding AvailableModels.Count, StringFormat='{}{0} available'}"
                               FontSize="12" Foreground="#7a6f96" VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                </DockPanel>

                <TextBox Watermark="search models..." Text="{Binding ModelSearchQuery}"
                         Background="#1a1425" BorderBrush="#2a2238" BorderThickness="1"
                         CornerRadius="8" Padding="10,8" FontSize="13" Foreground="#e8e0f4" />

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="32">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Background="#1e1730" Padding="10,4" Cursor="Hand">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#b0a4c8" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <ScrollViewer Margin="0,8,0,0" Padding="8,0">
                <ItemsControl ItemsSource="{Binding AvailableModels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    Cursor="Hand" CornerRadius="8"
                                    Command="{Binding $parent[UserControl].((NtwineApp.ViewModels.MainViewModel)DataContext).AddModelCommand}"
                                    CommandParameter="{Binding}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Border CornerRadius="4" Padding="4,2" Background="#0f2a1f"
                                                IsVisible="{Binding IsFree}">
                                            <TextBlock Text="free" FontSize="10" FontWeight="Bold" Foreground="#10b981" />
                                        </Border>
                                        <TextBlock Text="{Binding ContextDisplay}" FontSize="10" Foreground="#7a6f96" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#e8e0f4" />
                                            <TextBlock Text="{Binding CostLabel}" FontSize="10" Foreground="#7a6f96" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Provider}" FontSize="11" Foreground="#7a6f96" />
                                            <TextBlock Text="{Binding CostDetail}" FontSize="10" Foreground="#585070" />
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
