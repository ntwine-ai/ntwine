<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NtwineApp.ViewModels"
        x:Class="NtwineApp.MainWindow"
        Title="ntwine"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="38"
        SystemDecorations="Full">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="260,*">

        <!-- sidebar -->
        <Border Grid.Column="0" Classes="sidebar">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,48,16,12">
                    <TextBlock Text="ntwine" FontSize="18" FontWeight="Bold" Foreground="#8b7cf8" />
                    <TextBlock Text="AI agents that code together" Classes="muted" Margin="0,2,0,0" />
                </StackPanel>

                <Button DockPanel.Dock="Top" Classes="primary" Margin="16,4,16,12"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Content="New Discussion" Command="{Binding NewDiscussionCommand}" />

                <Button DockPanel.Dock="Top" Background="#1a1425" CornerRadius="8" Margin="16,0,16,12" Padding="10,8"
                        BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Cursor="Hand" Command="{Binding SelectProjectCommand}">
                    <StackPanel>
                        <TextBlock Text="PROJECT" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ProjectDisplayName, FallbackValue='click to select...'}"
                                   FontSize="12" Foreground="#b0a4c8" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <ScrollViewer DockPanel.Dock="Top" Margin="8,0">
                    <StackPanel Spacing="2">
                        <TextBlock Text="RECENT" Classes="muted" Margin="8,8,0,4" FontSize="10" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding Threads}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="sidebar-item" Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).LoadThreadCommand}"
                                            CommandParameter="{Binding}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Timestamp}" FontSize="9" Foreground="#585070" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16" Spacing="4">
                    <Separator Background="#1e1730" Height="1" Margin="0,0,0,8" />
                    <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="6" Height="6" CornerRadius="3" Background="#585070" VerticalAlignment="Center" />
                            <TextBlock Text="Login" FontSize="12" Foreground="#b0a4c8" />
                        </StackPanel>
                    </Button>
                    <Button Classes="ghost" Content="Settings" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Command="{Binding ToggleSettingsCommand}" />
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- main area -->
        <Panel Grid.Column="1">

            <!-- normal view (chat + composer) -->
            <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding !IsSettingsOpen}">

                <!-- top bar -->
                <Border Grid.Row="0" Background="#110d18" Padding="16,10" BorderBrush="#1e1730" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                            <Border Background="#1e1730" CornerRadius="6" Padding="8,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding AgentCount}" FontSize="12" FontWeight="Bold" Foreground="#8b7cf8" />
                                    <TextBlock Text="agents" FontSize="12" Classes="muted" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1e1730" CornerRadius="6" Padding="8,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding ToolCount}" FontSize="12" FontWeight="Bold" Foreground="#10b981" />
                                    <TextBlock Text="tools" FontSize="12" Classes="muted" />
                                </StackPanel>
                            </Border>
                            <Border Background="#1e1730" CornerRadius="6" Padding="8,4">
                                <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#7a6f96" />
                            </Border>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding CurrentDiscussionTitle}"
                                   Classes="heading" FontSize="16" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- chat + spec split -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                    <!-- messages -->
                    <Panel Grid.Column="0">

                        <!-- empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                                    IsVisible="{Binding !HasMessages}">
                            <TextBlock Text="what are we building?" FontSize="28" FontWeight="Bold"
                                       Foreground="#2a2238" HorizontalAlignment="Center" />
                            <TextBlock Text="pick some models, select a project, and describe the task"
                                       FontSize="13" Foreground="#3d3555" HorizontalAlignment="Center" />
                        </StackPanel>

                        <ScrollViewer Padding="24,16" Name="ChatScroll" IsVisible="{Binding HasMessages}">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="12,8" Margin="0,2"
                                            Background="{Binding BackgroundColor}">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="7" Height="7" CornerRadius="4"
                                                        Background="{Binding AgentColor}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding AgentName}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding AgentColor}" />
                                                <TextBlock Text="{Binding Timestamp}" FontSize="9" Foreground="#585070"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{Binding TextColor}" Margin="13,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    </Panel>

                    <!-- shared spec panel (shows when notes exist) -->
                    <Border Grid.Column="1" Width="300" Background="#0f0b15" BorderBrush="#1e1730" BorderThickness="1,0,0,0"
                            IsVisible="{Binding HasNotes}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="12,8" BorderBrush="#1e1730" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="Shared Spec" FontSize="13" FontWeight="SemiBold" Foreground="#8b7cf8" />
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#10b981"
                                            VerticalAlignment="Center" HorizontalAlignment="Right" IsVisible="{Binding IsRunning}" />
                                </DockPanel>
                            </Border>
                            <ScrollViewer Padding="12,8">
                                <TextBlock Text="{Binding SharedNotes}" TextWrapping="Wrap" FontSize="12"
                                           Foreground="#b0a4c8" FontFamily="JetBrains Mono,monospace" LineHeight="20" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- composer -->
                <Border Grid.Row="2" Margin="24,0,24,16">
                    <StackPanel>

                        <!-- model pills -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ItemsControl ItemsSource="{Binding SelectedModels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="16" Background="#1e1730" BorderBrush="#2a2238" BorderThickness="1" Padding="8,4,4,4">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Border Width="6" Height="6" CornerRadius="3" Background="{Binding Color}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="#b0a4c8" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding CostDetail}" FontSize="9" Foreground="#585070" VerticalAlignment="Center" />
                                                    <Button Background="Transparent" BorderThickness="0" Padding="3"
                                                            Cursor="Hand" CornerRadius="8" Width="18" Height="18"
                                                            Tag="{Binding ModelId}" Click="OnRemoveModelClick"
                                                            VerticalAlignment="Center" HorizontalContentAlignment="Center">
                                                        <TextBlock Text="x" FontSize="9" Foreground="#585070" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="ghost" Content="+ Add" FontSize="11" Command="{Binding ShowAddModelCommand}" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- input area -->
                        <Border Classes="composer" BorderBrush="{Binding ActiveModeBrush}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <!-- mode cycler -->
                                    <Button Background="Transparent" BorderThickness="0" Padding="6,4" Cursor="Hand"
                                            Command="{Binding CycleModeCommand}" CornerRadius="8" ToolTip.Tip="click to switch mode">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{Binding ActiveModeColor}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ActiveModeDisplayName}" FontSize="11" Foreground="{Binding ActiveModeColor}" FontWeight="SemiBold" />
                                            <TextBlock Text="&#x25B8;" FontSize="9" Foreground="#585070" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Border Width="1" Height="14" Background="#2a2238" Margin="2,0" VerticalAlignment="Center" />

                                    <!-- backend status -->
                                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding BackendConnected}" VerticalAlignment="Center">
                                        <Border Width="5" Height="5" CornerRadius="3" Background="#10b981" VerticalAlignment="Center" />
                                        <TextBlock Text="connected" FontSize="10" Foreground="#10b981" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding !BackendConnected}" VerticalAlignment="Center">
                                        <Border Width="5" Height="5" CornerRadius="3" Background="#ef4444" VerticalAlignment="Center" />
                                        <TextBlock Text="offline" FontSize="10" Foreground="#ef4444" />
                                    </StackPanel>
                                </StackPanel>

                                <Grid>
                                    <TextBox Classes="borderless" Text="{Binding PromptText}" MinHeight="50" MaxHeight="180"
                                             Watermark="describe what you want to build..." />
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4">
                                        <Button Classes="ghost" Content="Stop" FontSize="11"
                                                IsVisible="{Binding IsRunning}" Command="{Binding StopDiscussionCommand}" />
                                        <Button Classes="primary" Content="Start"
                                                IsVisible="{Binding !IsRunning}" Command="{Binding StartDiscussionCommand}" />
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- model picker overlay (t3.chat style) -->
            <Border IsVisible="{Binding IsModelPickerOpen}" Background="#0c0810" CornerRadius="12"
                    BorderBrush="#2a2238" BorderThickness="1" Margin="60,50,60,40">
                <DockPanel>

                    <!-- search + done -->
                    <Border DockPanel.Dock="Top" Padding="12,10" BorderBrush="#1e1730" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Classes="primary" Content="Done" Padding="12,6" FontSize="11"
                                    Command="{Binding ShowAddModelCommand}" Margin="8,0,0,0" />
                            <TextBox Background="#1a1425" BorderBrush="#2a2238" BorderThickness="1"
                                     CornerRadius="8" Padding="10,7" Watermark="Search models..."
                                     Text="{Binding ModelSearchQuery}" FontSize="13" Foreground="#e8e0f4" />
                        </DockPanel>
                    </Border>

                    <!-- two column layout: provider sidebar + model list -->
                    <Grid ColumnDefinitions="56,*">

                        <!-- left: provider icon sidebar -->
                        <Border Grid.Column="0" BorderBrush="#1e1730" BorderThickness="0,0,1,0" Background="#0a0812">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ProviderFilters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0"
                                                    Width="44" Height="44" Padding="0"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Cursor="Hand" CornerRadius="10" Margin="6,2"
                                                    ToolTip.Tip="{Binding Name}" Tag="{Binding Name}" Click="OnProviderClick">
                                                <Panel>
                                                    <Image Source="{Binding Logo}" Width="24" Height="24"
                                                           IsVisible="{Binding Logo, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                    <Border Width="28" Height="28" CornerRadius="14" Background="{Binding InitialColor}"
                                                            IsVisible="{Binding Logo, Converter={x:Static ObjectConverters.IsNull}}"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Initial}" FontSize="12" FontWeight="Bold" Foreground="#ffffff"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </Panel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- right: model list -->
                        <ScrollViewer Grid.Column="1">
                            <StackPanel Spacing="0" Margin="4,4,4,4">
                                <ItemsControl ItemsSource="{Binding FilteredModels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0" Padding="12,0"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                    Cursor="Hand" CornerRadius="8" Margin="0,1"
                                                    Tag="{Binding Id}" Click="OnModelRowClick">
                                                <Grid ColumnDefinitions="*,Auto" Height="56">
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#e8e0f4" />
                                                            <TextBlock Text="{Binding CostLabel}" FontSize="10"
                                                                       Foreground="{Binding CostColor}" VerticalAlignment="Center"
                                                                       FontFamily="JetBrains Mono,monospace" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Provider}" FontSize="11" Foreground="#585070" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border CornerRadius="4" Background="#0f2a1f" Padding="6,2" IsVisible="{Binding IsFree}">
                                                            <TextBlock Text="free" FontSize="9" FontWeight="Bold" Foreground="#10b981" />
                                                        </Border>
                                                        <Border CornerRadius="4" Background="#1e1730" Padding="6,2">
                                                            <TextBlock Text="{Binding ContextDisplay}" FontSize="9" Foreground="#7a6f96" />
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </DockPanel>
            </Border>

            <!-- settings view -->
            <ScrollViewer IsVisible="{Binding IsSettingsOpen}" Padding="40,50,40,20" Background="#110d18">
                <StackPanel MaxWidth="520" Spacing="24">

                    <!-- header -->
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Classes="ghost" Content="Close" Command="{Binding ToggleSettingsCommand}" />
                        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#e8e0f4" />
                    </DockPanel>

                    <!-- account -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACCOUNT" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                        <Border Background="#1a1425" CornerRadius="10" Padding="14,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Classes="ghost" Content="Login" FontSize="12" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="not signed in" FontSize="13" Foreground="#b0a4c8" />
                                    <TextBlock Text="sign in for cloud sync and credit billing" FontSize="11" Foreground="#585070" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <Separator Background="#1e1730" Height="1" />

                    <!-- theme -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="APPEARANCE" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border CornerRadius="8" Background="#1e1730" Padding="14,8" Cursor="Hand"
                                    BorderBrush="#8b7cf8" BorderThickness="1">
                                <TextBlock Text="Dark" FontSize="12" Foreground="#e8e0f4" />
                            </Border>
                            <Border CornerRadius="8" Background="#1a1425" Padding="14,8" Cursor="Hand"
                                    BorderBrush="#2a2238" BorderThickness="1">
                                <TextBlock Text="Light" FontSize="12" Foreground="#7a6f96" />
                            </Border>
                            <Border CornerRadius="8" Background="#1a1425" Padding="14,8" Cursor="Hand"
                                    BorderBrush="#2a2238" BorderThickness="1">
                                <TextBlock Text="System" FontSize="12" Foreground="#7a6f96" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1e1730" Height="1" />

                    <!-- BYOK -->
                    <StackPanel Spacing="10">
                        <DockPanel>
                            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding ByokEnabled}"
                                          OnContent="" OffContent="" Margin="0,0,0,0" />
                            <StackPanel>
                                <TextBlock Text="BRING YOUR OWN KEYS" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="optional. your keys, your bill. unlimited everything." FontSize="11" Foreground="#585070" />
                            </StackPanel>
                        </DockPanel>

                        <StackPanel Spacing="6" IsVisible="{Binding ByokEnabled}">
                            <!-- api key rows -->
                            <ItemsControl ItemsSource="{Binding ApiKeys}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1425" CornerRadius="8" Padding="4" Margin="0,2">
                                            <Grid ColumnDefinitions="120,*,Auto">
                                                <Border Grid.Column="0" Background="#151020" CornerRadius="6" Padding="8,7" Margin="0,0,4,0">
                                                    <TextBlock Text="{Binding Provider}" FontSize="12" Foreground="#b0a4c8" />
                                                </Border>
                                                <TextBox Grid.Column="1" Text="{Binding Key}" Watermark="{Binding Placeholder}"
                                                         PasswordChar="*" Background="Transparent" BorderThickness="0"
                                                         FontSize="12" Foreground="#e8e0f4" Padding="8,7" />
                                                <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                                                        Padding="6" Cursor="Hand" VerticalAlignment="Center"
                                                        Tag="{Binding Provider}" Click="OnRemoveKeyClick">
                                                    <TextBlock Text="x" FontSize="10" Foreground="#585070" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- add key button -->
                            <DockPanel Margin="0,4,0,0">
                                <Button DockPanel.Dock="Right" Classes="ghost" Content="+ Add" FontSize="11"
                                        Command="{Binding AddApiKeyCommand}" />
                                <ComboBox ItemsSource="{Binding AvailableProviders}" SelectedItem="{Binding NewKeyProvider}"
                                          Background="#1a1425" BorderBrush="#2a2238" CornerRadius="8"
                                          FontSize="12" Foreground="#b0a4c8" Padding="8,5" Width="160" />
                            </DockPanel>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1e1730" Height="1" />

                    <StackPanel Spacing="8">
                        <DockPanel>
                            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding CloudSyncEnabled}" OnContent="" OffContent="" />
                            <StackPanel>
                                <TextBlock Text="CLOUD SYNC" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="sync threads across devices. requires login." FontSize="11" Foreground="#585070" />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                    <Separator Background="#1e1730" Height="1" />

                    <!-- backend -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="BACKEND" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                        <Border Background="#1a1425" CornerRadius="8" Padding="12,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#10b981"
                                            IsVisible="{Binding BackendConnected}" />
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#ef4444"
                                            IsVisible="{Binding !BackendConnected}" />
                                    <TextBlock Text="connected" FontSize="11" Foreground="#10b981"
                                               IsVisible="{Binding BackendConnected}" />
                                    <TextBlock Text="offline" FontSize="11" Foreground="#ef4444"
                                               IsVisible="{Binding !BackendConnected}" />
                                </StackPanel>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="localhost:8090" FontSize="12" Foreground="#b0a4c8" />
                                    <TextBlock Text="{Binding ToolCount, StringFormat='{}{0} tools registered'}" FontSize="10" Foreground="#585070" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <Separator Background="#1e1730" Height="1" />

                    <!-- danger zone -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="DATA" Classes="muted" FontSize="10" FontWeight="SemiBold" />
                        <Button Classes="ghost" Content="Clear all threads" HorizontalAlignment="Left" FontSize="12"
                                Command="{Binding ClearAllThreadsCommand}" />
                        <Button Classes="ghost" Content="Reset settings" HorizontalAlignment="Left" FontSize="12" />
                    </StackPanel>

                    <Button Classes="primary" Content="Save" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding SaveSettingsCommand}" Margin="0,8,0,20" />
                </StackPanel>
            </ScrollViewer>

        </Panel>
    </Grid>
</Window>
